packages:
  yum:
    certbot: []

files:
  "/tmp/nginx-pre-ssl.conf":
    mode: "000644"
    owner: root
    group: root
    content: |
      server {
        listen 80;
        server_name anatoliahorizon.com www.anatoliahorizon.com;

        location /.well-known/acme-challenge/ {
          root /var/www/letsencrypt;
          try_files $uri =404;
        }

        location / {
          proxy_pass http://127.0.0.1:8080;
          proxy_set_header Host $host;
          proxy_set_header X-Real-IP $remote_addr;
          proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        }
      }

commands:
  01_create_webroot:
    command: mkdir -p /var/www/letsencrypt

  02_backup_nginx:
    command: cp /etc/nginx/conf.d/elasticbeanstalk-nginx-docker-proxy.conf /tmp/nginx-backup.conf
    ignoreErrors: true

  03_temp_nginx_config:
    command: |
      cp /tmp/nginx-pre-ssl.conf /etc/nginx/conf.d/https.conf
      nginx -t && service nginx reload
    ignoreErrors: true

  04_get_ssl:
    command: |
      if [ ! -d "/etc/letsencrypt/live/anatoliahorizon.com" ]; then
        certbot certonly --webroot \
          -w /var/www/letsencrypt \
          --non-interactive \
          --agree-tos \
          --email demrekivrak@hotmail.com \
          -d anatoliahorizon.com \
          -d www.anatoliahorizon.com || echo "Certbot failed, continuing..."
      else
        echo "SSL certificate already exists"
      fi